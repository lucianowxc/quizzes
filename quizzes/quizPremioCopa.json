  "descriptions": {
    "bola_ouro": {
      "title": "Bola de Ouro",
      "emoji": "⭐",
      "subtitle": "O Destaque Natural",
      "text": "Você tem uma presença magnética e uma confiança inspiradora. As pessoas naturalmente olham para você em busca de liderança. Seu talento é inegável, mas o que realmente te destaca é a generosidade em compartilhar o protagonismo. Continue brilhando!"
    },
    "chuteira_ouro": {
      "title": "Chuteira de Ouro",
      "emoji": "⚽",
      "subtitle": "O Realizador",
      "text": "Você tem foco e determinação. Quando define uma meta, vai atrás com toda energia. É pragmático, objetivo e sabe exatamente o que quer. Seu maior presente é transformar planos em realidade — e inspirar os outros a fazerem o mesmo."
    },
    "luva_ouro": {
      "title": "Luva de Ouro",
      "emoji": "🧤",
      "subtitle": "O Protetor",
      "text": "Você é a pessoa que segura a onda quando tudo parece desabar. Calmo, paciente e confiável, você é o porto seguro do seu time. Pode não ser o centro das atenções, mas todos sabem que sem você, o caos reinaria. Sua força está na constância."
    },
    "jovem_revelacao": {
      "title": "Melhor Jogador Jovem",
      "emoji": "🌱",
      "subtitle": "O Curioso",
      "text": "Você tem a energia de quem está começando, mas com a sabedoria de quem já entende do jogo. É curioso, aberto a aprender e não tem medo de errar — porque sabe que cada erro é um degrau. Seu futuro é promissor e sua humildade é seu maior trunfo."
    },
    "fair_play": {
      "title": "Fair Play",
      "emoji": "🤝",
      "subtitle": "O Equilibrado",
      "text": "Você acredita que o caminho importa tanto quanto o destino. É ético, respeitoso e sempre busca o melhor para o grupo. Sua habilidade de ouvir e mediar conflitos é rara. O mundo precisa de mais pessoas como você, que colocam o coletivo acima do ego."
    },
    "gol_torneio": {
      "title": "Gol do Torneio",
      "emoji": "🎬",
      "subtitle": "O Criativo",
      "text": "Você enxerga beleza onde outros veem apenas rotina. É criativo, imaginativo e não tem medo de ousar. Sua abordagem única transforma o ordinário em extraordinário. Às vezes as pessoas demoram a entender sua visão, mas quando entendem, se encantam."
    },
    "selecao_divertida": {
      "title": "Seleção Mais Divertida",
      "emoji": "🎊",
      "subtitle": "O Iluminador",
      "text": "Você tem o dom de transformar qualquer ambiente em um lugar mais leve. Seu sorriso é contagiante e sua presença, revigorante. Sabe que a vida é feita de momentos, e faz questão de torná-los memoráveis. Continue espalhando essa energia tão especial!"
    }
  }
